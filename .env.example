APP_URL=http://localhost:3000
DATABASE_URL="postgresql://user:password@localhost:5432/db"
# APP_SECRET=
# DISABLE_DB_WARN=true

# AI vision provider (ollama | openai | anthropic | gemini | custom)
# VISION_PROVIDER=ollama

# Ollama (default provider)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2-vision

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# Custom OpenAI-compatible provider
# CUSTOM_BASE_URL=http://localhost:8080/v1
# CUSTOM_MODEL=llama3.2-vision
# CUSTOM_API_KEY=

# SMTP (optional — without it, magic links are printed in the server console)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=contact@example.com
# SMTP_PASSWORD=password
# SMTP_FROM="QardQntac <contact@example.com>"

# UI language
# LOCALE=en

# Auth — allowed email domains
# AUTH_WHITELISTED_DOMAINS=example.com,other.com

# Disable new registrations
# AUTH_ALLOW_REGISTRATION=true

# Additional trusted CORS origins (optional)
# AUTORIZED_DOMAINS=https://app.example.com
