APP_URL=http://192.168.1.213:3000
APP_SECRET=
DATABASE_URL="postgresql://user:password@localhost:5432/db"

# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2-vision
# VISION_PROVIDER=ollama

# SMTP (optional — without it, magic links are printed in the server console)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=contact@example.com
# SMTP_PASSWORD=password
# SMTP_FROM="KardQntact <contact@example.com>"

# OpenAI (required if VISION_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Anthropic (required if VISION_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini (required if VISION_PROVIDER=gemini)
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# UI language (fr or en, default: en)
# LOCALE=en

# Auth — allowed email domains (empty = all allowed)
# AUTH_WHITELISTED_DOMAINS=example.com,other.com

# Disable new registrations (default: true)
# AUTH_ALLOW_REGISTRATION=true

# Additional trusted CORS origins (optional)
# AUTORIZED_DOMAINS=https://app.example.com
